# ── Database ────────────────────────────────────────────────────────────────
# Switch by changing DATABASE_URL (the only thing Prisma reads).
#
# Local Postgres (default). For Docker compose use port 5433 + flyuser/flypass.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flytogether?schema=public"
#
# UAT — Neon: swap DATABASE_URL to your Neon connection string. SSL is required,
# and use Neon's DIRECT (non-pooled) endpoint so migrations work too:
#   DATABASE_URL="postgresql://<user>:<password>@<ep-id>.<region>.aws.neon.tech/<db>?sslmode=require"
# (If you must use the pooled "-pooler" host, add `&pgbouncer=true` for runtime
#  and run migrations against the direct host instead.)
PORT=4000
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
CORS_ORIGIN="http://localhost:3000"
# Public base URL of this backend — baked into stored document URLs (docUrl).
BACKEND_URL="http://localhost:4000"
# Storage: "local" for local dev, "cloudinary" for UAT.
STORAGE_DRIVER="local"
UPLOAD_DIR="uploads"
SIGNED_URL_SECRET="dev-signed-url-secret"
SIGNED_URL_TTL_SECONDS="300"

# Cloudinary (required only when STORAGE_DRIVER="cloudinary").
# UAT example:
#   STORAGE_DRIVER="cloudinary"
#   CLOUDINARY_CLOUD_NAME="your-cloud-name"
#   CLOUDINARY_API_KEY="your-api-key"
#   CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Email ─────────────────────────────────────────────────────────────────────
# Delivery preference: Brevo HTTP API → SMTP → console log.
#
# Brevo (recommended for prod — Render & similar hosts BLOCK outbound SMTP):
#   1. Sign up at brevo.com, verify your sender email under Senders.
#   2. SMTP & API → API Keys → create a key, put it in BREVO_API_KEY.
#   3. Set MAIL_FROM to the verified sender. Sends over HTTPS, so no port blocks.
BREVO_API_KEY=""
#
# Gmail SMTP (works locally; blocked on Render):
#   1. Enable 2-Step Verification on the Google account.
#   2. Google Account → Security → App passwords → generate one for "Mail".
#   3. Put the Gmail address in SMTP_USER and the 16-char App Password in SMTP_PASS.
# If neither Brevo nor SMTP is set, emails are printed to the server console.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-account@gmail.com"
SMTP_PASS=""
MAIL_FROM="Fly Together <your-account@gmail.com>"

# ── Flywire Agents Payments API ───────────────────────────────────────────────
# Sandbox base + the X-Authentication-Key from the Agents portal
# (Settings > General > Integration Details). When FLYWIRE_API_KEY is empty the
# Flywire endpoints return 503 and the rest of the app keeps working.
FLYWIRE_API_BASE="https://api-platform.demo.flywire.com/agents"
FLYWIRE_API_KEY=""
# Sandbox test destinations: FLYWIRE:ANI (non-integrated, EUR) or FLYWIRE:AIN (integrated).
FLYWIRE_DESTINATION_ID="FLYWIRE:ANI"
# Default payer country (2-letter) for the Flywire subject.
FLYWIRE_SUBJECT_COUNTRY="IN"
