{
  "name": "fly-together-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:uat": "dotenv -e .env.uat -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:uat": "dotenv -e .env.uat -- node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d",
    "prisma:migrate": "prisma migrate dev",
    "migrate:uat": "dotenv -e .env.uat -- prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "seed": "prisma migrate deploy && tsx prisma/seed.ts",
    "seed:uat": "dotenv -e .env.uat -- prisma migrate deploy && dotenv -e .env.uat -- tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
