# UAT environment — copy to `.env.uat` and fill in real values.
# Loaded only by the *:uat scripts (dotenv -e .env.uat). This file must be
# COMPLETE: when running UAT the local .env is NOT merged in.

# Neon Postgres (use the DIRECT / non-pooled endpoint; SSL required).
DATABASE_URL="postgresql://<user>:<password>@<ep-id>.<region>.aws.neon.tech/<db>?sslmode=require"

PORT=4000
JWT_ACCESS_SECRET="change-me-uat-access"
JWT_REFRESH_SECRET="change-me-uat-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
CORS_ORIGIN="https://your-uat-frontend.example.com"
FRONTEND_URL="https://your-uat-frontend.example.com"
# Public base URL of the UAT backend — baked into stored document URLs.
BACKEND_URL="https://your-uat-api.example.com"
RESET_TOKEN_TTL_MINUTES="60"
SIGNED_URL_SECRET="change-me-uat-signed-url"
SIGNED_URL_TTL_SECONDS="300"

# Storage: Cloudinary in UAT.
STORAGE_DRIVER="cloudinary"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Optional SMTP — if unset, password-reset emails are printed to the console.
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
MAIL_FROM="Fly Together <no-reply@flytogether.com>"
